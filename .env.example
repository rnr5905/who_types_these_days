# Voice Dictation Configuration

# OS: Linux, Darwin (macOS), Windows
# Auto-detected if not set

SYSTEM=Linux

# STT Backend: vosk (local), groq (cloud), deepgram (cloud)
STT_BACKEND=deepgram

# API Keys (get free keys at console.groq.com and console.deepgram.com)
GROQ_API_KEY=
DEEPGRAM_API_KEY=

# Recording Limits
MAX_RECORDING_SECONDS=120
COOLDOWN_SECONDS=3
LONG_RECORDING_THRESHOLD=60
