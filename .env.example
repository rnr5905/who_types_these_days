# Voice Dictation Configuration
# Copy this file to .env and customize

# STT Backend: "vosk" (local), "groq" (cloud), "deepgram" (cloud)
STT_BACKEND=deepgram

# Groq API - Free tier available
# Get key at: https://console.groq.com
GROQ_API_KEY=

# Deepgram API - $200 free credit
# Get key at: https://console.deepgram.com
DEEPGRAM_API_KEY=

# Audio Settings
SAMPLE_RATE=16000

# Recording Limits
MAX_RECORDING_SECONDS=120
COOLDOWN_SECONDS=3
LONG_RECORDING_THRESHOLD=60
